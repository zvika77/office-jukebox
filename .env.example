ADMIN_TOKEN=change-me
PORT=8000
PUBLIC_URL=http://localhost:8000
DB_PATH=jukebox.db
# Optional — enables the "Refresh suggestions" button on the phone view.
# Get a free key: Google Cloud Console → enable YouTube Data API v3 → create an API key.
YOUTUBE_API_KEY=
# Optional — when set, Quick Add pulls from this playlist instead of the built-in song lists.
# Paste the full playlist URL or just the list ID (the PLxxx... part after ?list=).
# The playlist must be public or unlisted.
YOUTUBE_PLAYLIST_ID=
